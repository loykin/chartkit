{
  "compilerOptions": {
    "target":           "ES2020",
    "lib":              ["ES2020", "DOM", "DOM.Iterable"],
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "jsx":              "react-jsx",
    "strict":           true,
    "skipLibCheck":     true,
    "paths": {
      "@loykin/chartkit":         ["../src/index.ts"],
      "@loykin/chartkit/styles":  ["../src/styles/index.css"]
    }
  },
  "include": ["src"]
}

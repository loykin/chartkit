{
  "name": "@loykin/chartkit",
  "version": "0.0.1-beta.1",
  "description": "A React chart component library built on uPlot — TimeSeriesChart, HistogramChart, and more.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": {
      "types": "./dist/styles.d.ts",
      "default": "./dist/styles.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit && eslint src --ext .ts,.tsx && tsup && node scripts/build-css.mjs && echo 'declare const styles: string; export default styles;' > dist/styles.d.ts",
    "build:js": "tsup",
    "build:css": "node scripts/build-css.mjs",
    "dev": "concurrently \"tsup --watch\" \"pnpm --filter chartkit-playground dev\"",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "lucide-react": "^1.11.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uplot": "^1.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jiti": "^2.6.1",
    "prettier": "^3.8.2",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "uplot": "^1.6.32",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "react",
    "chart",
    "timeseries",
    "histogram",
    "uplot",
    "canvas"
  ],
  "license": "MIT"
}
